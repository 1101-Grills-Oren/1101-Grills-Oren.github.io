struct BlockSoundGroupRecord {
	volume: float,
	pitch: float,
	break_sound: #[id="sound_event"] string,
	step_sound: #[id="sound_event"] string,
	place_sound: #[id="sound_event"] string,
	hit_sound: #[id="sound_event"] string,
	fall_sound: #[id="sound_event"] string,	
}
