use ::java::util::color::DyeColor
use ::java::util::attribute::AttributeOperation
dispatch minecraft:resource[quality_commands:data_block] to struct BlockSettingsRecord {
	///must be set to namespace of block
	namespace: string,
	///must be set to path of block
	id: string,
	///block type; can either be the id of a vanilla block to copy, `ExplosiveBlock`, `FacingExplosiveBlock`,`Block`, or `AmalgamBlock`.
	///Defaults to `Block`
	type?: string,
	explodeCommand?: string,
	onExplodedCommand?: string,
	standardProperties?: StandardProperties,
	///Unused unless the block is of type `AmalgamBlock`
	amalgamSpecific?: AmalgamSpecific,
	arguments?: [blockargument],
	///List of block tags. Block tags CANNOT be set in the normal way for these blocks.
	tags?: [string],
}
type blockargument=((#[id="block"] string)|("#"+(#[color="hex_rgb"] string)))
dispatch minecraft:resource[quality_commands:data_effect] to struct CustomStatusEffectRecord {
	category: StatusEffectCategory,
    color: #[color="composite_rgb"] int,
	attributeModifiers?:AttributeModifiers,
    tickCommand?: string,
    applyCommand?: string,
    damageEntityCommand?:string,
    removeEntityCommand?:string,
	///List of model overlay textures. Example: ```"minecraft:textures/item/texture_name.png"```
	overlays?:[string]
}
enum(string) StatusEffectCategory{
	Beneficial = "beneficial",
    Harmful = "harmful",
    Neutral = "neutral",
}
struct AttributeModifiers {
	[#[id="attribute"] string] : AttributeModifier,
}
struct AttributeModifier {
	id:string,
	base_value: double,
	operation: AttributeOperation,
}

struct StandardProperties {
	///Block to copy property from. 
	parent?: #[id="block"] string,
	///Color that this block should appear as on the map. Defaults to purple.
	mapColor?: MapColor,
	///should the block be transparent? defaults to false
	nonOpaque?: boolean,
	///If the block should have no collision. Also sets nonOpaque to true when true. Defaults to false.
	noCollision?: boolean,
	///block slipperiness. Defaults to 0
	slipperiness?: float,
	///multiplies current velocity every tick. Defaults to 1
	velocityMultiplier?: float,
	///Multiplier applied to jump strength. Defaults to 1
	jumpVelocityMultiplier?: float,
	hardness?: float,
	resistance?: float,
	soundGroup?: BlockSoundGroup,
}
